{
  "mcpServers": {
    "ClickUp": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@taazkareem/clickup-mcp-server@latest"],
      "env": {
        "CLICKUP_API_KEY": "${env:CLICKUP_API_KEY}",
        "CLICKUP_TEAM_ID": "${env:CLICKUP_TEAM_ID}",
        "CLICKUP_MCP_LICENSE_KEY": "${env:CLICKUP_MCP_LICENSE_KEY}"
      }
    }
  }
}
